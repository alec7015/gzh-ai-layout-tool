{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "公众号AI排版器",
  "version": "0.1.0",
  "identifier": "com.local.gzhlayout",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "公众号AI排版器",
        "width": 1280,
        "height": 780,
        "minWidth": 1024,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
